{
  "name": "firehose-ethereum-battlefield",
  "version": "1.0.0",
  "description": "Firehose Tracers test suites for Ethereum chain(s)",
  "scripts": {
    "compile": "hardhat compile",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "generate": "buf generate buf.build/streamingfast/firehose-ethereum",
    "generate:local": "buf generate ../firehose-ethereum/proto",
    "test:fh3.0:geth-dev": "cross-env SNAPSHOTS_TAG=fh3.0/geth-dev hardhat test --network geth-dev",
    "test:fh3.0:reth-dev": "cross-env SNAPSHOTS_TAG=fh3.0/reth-dev hardhat test --network reth-dev",
    "test:fh3.0:sei-dev": "cross-env SNAPSHOTS_TAG=fh3.0/sei-dev hardhat test --network sei-dev",
    "test:fh3.0:bnb-dev": "cross-env SNAPSHOTS_TAG=fh3.0/bnb-dev hardhat test --network bnb-dev",
    "test:fh3.0:polygon-dev": "cross-env SNAPSHOTS_TAG=fh3.0/polygon-dev hardhat test --network polygon-dev",
    "test:fh3.0:optimism-devnet": "cross-env SNAPSHOTS_TAG=fh3.0/optimism-devnet hardhat test --network optimism-devnet",
    "test:fh3.0:optimism-geth-dev": "cross-env SNAPSHOTS_TAG=fh3.0/optimism-geth-dev hardhat test --network optimism-geth-dev",
    "test:fh3.0:besu-devnet": "cross-env SNAPSHOTS_TAG=fh3.0/besu-devnet hardhat test --network besu-devnet",
    "test:fh3.0:amoy": "cross-env SNAPSHOTS_TAG=fh3.0/amoy hardhat test --network amoy",
    "test:fh3.0:monad-dev": "cross-env SNAPSHOTS_TAG=fh3.0/monad-dev bash scripts/run_monad_devnet.sh",
    "test:fh2.3:arbitrum-geth-dev": "cross-env SNAPSHOTS_TAG=fh2.3/arbitrum-geth-dev hardhat test --network arbitrum-geth-dev"
  },
  "keywords": [],
  "author": "",
  "license": "Private",
  "devDependencies": {
    "@bufbuild/buf": "^1.47.2",
    "@bufbuild/protobuf": "^2.2.2",
    "@bufbuild/protoc-gen-es": "^2.2.2",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/deep-equal": "^1.0.4",
    "diff": "^5.2.0",
    "@types/mocha": ">=9.1.0",
    "@types/node": ">=18.0.0",
    "chai": "^4.2.0",
    "cross-env": "^7.0.3",
    "debug": "^4.3.7",
    "deep-equal": "^2.2.3",
    "ethers": "^6.16.0",
    "hardhat": "^2.24.2",
    "hardhat-gas-reporter": "^1.0.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.1",
    "solidity-coverage": "^0.8.0",
    "ts-node": ">=8.0.0",
    "typechain": "^8.3.0",
    "typescript": ">=4.5.0"
  },
  "dependencies": {
    "@types/debug": "^4.1.12",
    "c-kzg": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["c-kzg", "keccak", "secp256k1"]
  }
}
